{
  "name": "@geekflare/mcp",
  "version": "0.3.7",
  "description": "Official MCP server for Geekflare API",
  "type": "module",
  "bin": {
    "geekflare-mcp": "build/index.js"
  },
  "main": "./build/index.js",
  "files": [
    "build",
    "README.md"
  ],
  "mcpName": "com.geekflare/mcp",
  "scripts": {
    "build": "tsc && shx chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "ts-node src/index.ts",
    "test": "tsx test.ts",
    "prepublishOnly": "npm test && npm run build",
    "docker:build": "docker build -t geekflarehq/geekflare-api-mcp:latest .",
    "docker:push": "docker push geekflarehq/geekflare-api-mcp:latest",
    "release": "npm test && docker build -t geekflarehq/geekflare-api-mcp:latest . && docker push geekflarehq/geekflare-api-mcp:latest"
  },
  "keywords": [
    "geekflare",
    "mcp",
    "api",
    "scraping",
    "screenshot",
    "dns",
    "model-context-protocol"
  ],
  "author": "Geekflare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geekflare/geekflare-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/geekflare/geekflare-mcp/issues"
  },
  "homepage": "https://github.com/geekflare/geekflare-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "dotenv": "^16.6.1",
    "json-schema-to-zod": "^2.8.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "shx": "^0.3.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
